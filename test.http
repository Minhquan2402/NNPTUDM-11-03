@baseUrl = http://localhost:3000/api/v1
@roleId = REPLACE_ROLE_ID
@userId = REPLACE_USER_ID

### 0) API root
GET {{baseUrl}}

### 1) Create role
POST {{baseUrl}}/roles
Content-Type: application/json

{
  "name": "admin",
  "description": "quan tri"
}

### 2) Get all roles (copy _id to @roleId)
GET {{baseUrl}}/roles

### 3) Get role by id
GET {{baseUrl}}/roles/{{roleId}}

### 4) Create user (replace roleId first)
POST {{baseUrl}}/users
Content-Type: application/json

{
  "username": "quan1",
  "password": "123456",
  "email": "quan1@gmail.com",
  "fullName": "Quan",
  "role": "{{roleId}}"
}

### 5) Get all users
GET {{baseUrl}}/users

### 6) Get user by id (copy _id to @userId)
GET {{baseUrl}}/users/{{userId}}

### 7) Enable user by email + username
POST {{baseUrl}}/users/enable
Content-Type: application/json

{
  "email": "quan1@gmail.com",
  "username": "quan1"
}

### 8) Disable user by email + username
POST {{baseUrl}}/users/disable
Content-Type: application/json

{
  "email": "quan1@gmail.com",
  "username": "quan1"
}

### 9) Get users by role id
GET {{baseUrl}}/roles/{{roleId}}/users

### 10) Update user by id
PUT {{baseUrl}}/users/{{userId}}
Content-Type: application/json

{
  "fullName": "Quan Updated",
  "loginCount": 3
}

### 11) Soft delete user
DELETE {{baseUrl}}/users/{{userId}}

### 12) Update role by id
PUT {{baseUrl}}/roles/{{roleId}}
Content-Type: application/json

{
  "description": "admin role updated"
}

### 13) Soft delete role
DELETE {{baseUrl}}/roles/{{roleId}}
